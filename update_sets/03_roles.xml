<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================
  UPDATE SET: 03 - Custom Roles
  Application: Project Task Management System (x_ptms)
  Description:
    Creates two custom roles scoped to x_ptms.
    ServiceNow best practice: always use scoped roles
    (prefixed with the app scope) rather than re-using
    platform roles like 'admin' or 'itil'.

  Roles Created:
    1. x_ptms.project_manager
       - Full CRUD on all Project Task records
       - Access to Dashboard and Reports modules
       - Can create, modify, and delete tasks

    2. x_ptms.team_member
       - Read-only access to assigned tasks
       - Can update Status and Work Notes only
       - Cannot create or delete tasks

  Role Hierarchy:
    admin (platform)
      └── x_ptms.project_manager
      └── x_ptms.team_member
  ============================================================
-->
<unload log_date="2026-07-01">

  <!-- ═══════════════════════════════════════════════
       ROLE 1: Project Manager
       ═══════════════════════════════════════════════ -->
  <sys_user_role action="INSERT_OR_UPDATE">
    <sys_id>c1d2e3f4a5b6c1d2e3f4a5b6c1d2e3f1</sys_id>

    <!--
      Role name MUST be prefixed with the scope name.
      This prevents collision with other applications.
    -->
    <name>x_ptms.project_manager</name>

    <!-- Human-readable label shown in role pickers -->
    <description>
      Project Manager role for the Project Task Management System.
      Users with this role have full Create, Read, Update, and Delete
      access to all Project Task records, and can access the Dashboard
      and Reports modules.
    </description>

    <!-- Elevation not required — standard privileged role -->
    <elevated_privilege>false</elevated_privilege>

    <!-- Scoped to our application -->
    <sys_scope display_value="Project Task Management System">
      a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d1
    </sys_scope>

    <!-- Suffix used in the ACL role condition -->
    <suffix>project_manager</suffix>
  </sys_user_role>

  <!-- ═══════════════════════════════════════════════
       ROLE 2: Team Member
       ═══════════════════════════════════════════════ -->
  <sys_user_role action="INSERT_OR_UPDATE">
    <sys_id>c1d2e3f4a5b6c1d2e3f4a5b6c1d2e3f2</sys_id>

    <name>x_ptms.team_member</name>

    <description>
      Team Member role for the Project Task Management System.
      Users with this role can only read Project Task records
      that are assigned to them. They may update the Status
      and Work Notes fields of their own assigned tasks.
      Create and Delete operations are denied.
    </description>

    <elevated_privilege>false</elevated_privilege>

    <sys_scope display_value="Project Task Management System">
      a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d1
    </sys_scope>

    <suffix>team_member</suffix>
  </sys_user_role>

</unload>
