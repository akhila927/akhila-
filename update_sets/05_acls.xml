    <admin_overrides>true</admin_overrides>
    <sys_scope>a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d1</sys_scope>
  </sys_security_acl>

  <!-- Deny Team Member from editing Priority -->
  <sys_security_acl action="INSERT_OR_UPDATE">
    <sys_id>e1f2a3b4c5d6e1f2a3b4c5d6e1f2a3c5</sys_id>
    <name>x_ptms_project_task.priority — Field Write — Deny Team Member</name>
    <operation>write</operation>
    <type>field</type>
    <name display_value="x_ptms_project_task.priority">
      x_ptms_project_task.priority
    </name>
    <script><![CDATA[answer = false;]]></script>
    <roles>x_ptms.team_member</roles>
    <active>true</active>
    <admin_overrides>true</admin_overrides>
    <sys_scope>a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d1</sys_scope>
  </sys_security_acl>

  <!-- Deny Team Member from editing Due Date -->
  <sys_security_acl action="INSERT_OR_UPDATE">
    <sys_id>e1f2a3b4c5d6e1f2a3b4c5d6e1f2a3c6</sys_id>
    <name>x_ptms_project_task.due_date — Field Write — Deny Team Member</name>
    <operation>write</operation>
    <type>field</type>
    <name display_value="x_ptms_project_task.due_date">
      x_ptms_project_task.due_date
