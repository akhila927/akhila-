  <!-- Deny Team Member from editing Assigned To -->
  <sys_security_acl action="INSERT_OR_UPDATE">
    <sys_id>e1f2a3b4c5d6e1f2a3b4c5d6e1f2a3c4</sys_id>
    <name>x_ptms_project_task.assigned_to — Field Write — Deny Team Member</name>
